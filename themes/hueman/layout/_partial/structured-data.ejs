<%# --- JSON-LD Structured Data for SEO + GEO --- %>
<%
function absUrl(path) {
  if (!path) return config.url;
  if (path.startsWith('http://') || path.startsWith('https://')) return path;
  return config.url + url_for(path);
}

var authorName = config.author || 'Salty Egg';
var siteUrl = config.url;

var socialLinks = [];
if (theme.social_links) {
  for (var key in theme.social_links) {
    if (key !== 'rss' && theme.social_links[key]) {
      socialLinks.push(theme.social_links[key]);
    }
  }
}

// GEO: Detect post language from title using charCodeAt
function detectLang(pg) {
  function hasChinese(str) {
    if (!str) return false;
    for (var i = 0; i < str.length && i < 500; i++) {
      var code = str.charCodeAt(i);
      if (code >= 0x4e00 && code <= 0x9fff) return true;
      if (code >= 0x3400 && code <= 0x4dbf) return true;
    }
    return false;
  }
  return hasChinese(pg.title) ? 'zh-CN' : 'en';
}
%>

<%# --- WebSite Schema (all pages) --- %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "<%- siteUrl %>/#website",
  "url": "<%- siteUrl %>",
  "name": "<%- config.title %>",
  "description": "<%- config.description %>",
  "publisher": {
    "@id": "<%- siteUrl %>/#person"
  },
  "inLanguage": "<%= config.language && Array.isArray(config.language) ? config.language[0] : (config.language || 'en') %>"
}
</script>

<%# --- Person Schema (E-E-A-T + GEO entity linking) --- %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "<%- siteUrl %>/#person",
  "name": "<%- authorName %>",
  "url": "<%- siteUrl %>/about/",
  "jobTitle": "Software Engineer",
  "knowsAbout": ["Software Engineering", "Web Development", "AI", "System Design", "Java", "JavaScript", "Cloud Computing"],
  "sameAs": <%- JSON.stringify(socialLinks) %>
}
</script>

<% if (is_post()) { %>
<%# --- BlogPosting Schema (GEO-enhanced) --- %>
<%
  var postDesc = '';
  if (page.description) {
    postDesc = page.description;
  } else if (page.excerpt) {
    postDesc = strip_html(page.excerpt).replace(/\n/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 200);
  } else if (page.content) {
    postDesc = strip_html(page.content).replace(/\n/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 200);
  }

  var postImage = '';
  if (page.cover) {
    postImage = absUrl(page.cover);
  } else if (page.photos && page.photos.length) {
    postImage = absUrl(page.photos[0]);
  } else if (theme.default_og_image) {
    postImage = absUrl(theme.default_og_image);
  } else {
    postImage = absUrl(theme.logo || '/favicon.png');
  }

  var postTags = [];
  if (page.tags && page.tags.length) {
    page.tags.forEach(function(tag) {
      postTags.push(tag.name);
    });
  }

  // GEO: word count for schema
  var plainContent = strip_html(page.content || '');
  var wordCount = plainContent.replace(/\s+/g, ' ').trim().split(/\s+/).length;

  // GEO: first category as articleSection
  var articleSection = '';
  if (page.categories && page.categories.length) {
    page.categories.forEach(function(cat) {
      if (!articleSection) articleSection = cat.name;
    });
  }

  // GEO: per-post language
  // Don't use page.lang — it's Hexo's default, not per-post. Detect from content.
  var postLang = detectLang(page);
%>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": "<%- page.permalink %>#article",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "<%- page.permalink %>"
  },
  "headline": "<%- page.title %>",
  "description": "<%- postDesc.replace(/"/g, '\\"') %>",
  <% if (postImage) { %>
  "image": "<%- postImage %>",
  <% } %>
  "datePublished": "<%- page.date.toISOString() %>",
  "dateModified": "<%- (page.updated || page.date).toISOString() %>",
  "author": {
    "@id": "<%- siteUrl %>/#person"
  },
  "publisher": {
    "@id": "<%- siteUrl %>/#person"
  },
  "isPartOf": {
    "@id": "<%- siteUrl %>/#website"
  },
  "inLanguage": "<%= postLang %>",
  "wordCount": <%= wordCount %>,
  "isAccessibleForFree": true,
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".article-title", ".article-entry p:first-of-type"]
  }<% if (articleSection) { %>,
  "articleSection": "<%- articleSection %>"
  <% } %><% if (postTags.length > 0) { %>,
  "keywords": <%- JSON.stringify(postTags) %>
  <% } %>
}
</script>

<%# --- BreadcrumbList Schema --- %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "<%- siteUrl %>"
    }<% if (page.categories && page.categories.length) {
      var pos = 2;
      page.categories.forEach(function(cat) { %>,
    {
      "@type": "ListItem",
      "position": <%= pos %>,
      "name": "<%- cat.name %>",
      "item": "<%- absUrl(cat.path) %>"
    }<%
        pos++;
      });
    } %>,
    {
      "@type": "ListItem",
      "position": <%= (page.categories && page.categories.length) ? page.categories.length + 2 : 2 %>,
      "name": "<%- page.title %>",
      "item": "<%- page.permalink %>"
    }
  ]
}
</script>
<% } %>

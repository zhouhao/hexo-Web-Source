<!DOCTYPE html>
<%
// --- GEO: Per-post language detection ---
// Check for CJK Unified Ideographs using charCodeAt (avoids EJS unicode escape issues)
function hasChinese(str) {
  if (!str) return false;
  for (var i = 0; i < str.length && i < 500; i++) {
    var code = str.charCodeAt(i);
    if (code >= 0x4e00 && code <= 0x9fff) return true;
    if (code >= 0x3400 && code <= 0x4dbf) return true;
  }
  return false;
}
var pageLang = 'en';
if (is_post() || is_page()) {
  // Detect language from title only (raw/content may contain Chinese categories in English posts)
  if (hasChinese(page.title)) {
    pageLang = 'zh-CN';
  }
} else {
  pageLang = config.language && Array.isArray(config.language) ? config.language[0] : (config.language || 'en');
}
%>
<html lang="<%= pageLang %>">
<head>
  <meta charset="utf-8">

  <%# --- Performance: Resource hints (before anything else) --- %>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="//fonts.googleapis.com">
  <link rel="dns-prefetch" href="//cdn.datatables.net">
  <link rel="dns-prefetch" href="//code.jquery.com">
  <link rel="dns-prefetch" href="//www.googletagmanager.com">
  <link rel="dns-prefetch" href="//pagead2.googlesyndication.com">

  <%
  var title = page.title;

  if (is_archive()){
    title = 'Archives';

    if (is_month()){
      title += ': ' + page.year + '/' + page.month;
    } else if (is_year()){
      title += ': ' + page.year;
    }
  } else if (is_category()){
    title = 'Category: ' + page.category;
  } else if (is_tag()){
    title = 'Tag: ' + page.tag;
  }

  // --- SEO: description fallback chain ---
  var seoDesc = '';
  if (page.description) {
    seoDesc = page.description;
  } else if (page.excerpt) {
    seoDesc = strip_html(page.excerpt).replace(/\n/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 200);
  } else if ((is_post() || is_page()) && page.content) {
    seoDesc = strip_html(page.content).replace(/\n/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 200);
  }
  if (!seoDesc) {
    seoDesc = config.description || '';
  }

  // --- SEO: keywords from tags ---
  var seoKeywords = '';
  if (page.tags && page.tags.length) {
    seoKeywords = page.tags.map(function(tag) { return tag.name; }).join(',');
  } else if (page.keywords) {
    seoKeywords = page.keywords;
  } else if (config.keywords) {
    seoKeywords = Array.isArray(config.keywords) ? config.keywords.join(',') : config.keywords;
  }

  // --- SEO: Open Graph image ---
  var ogImage = null;
  if (page.cover) {
    ogImage = page.cover;
  } else if (page.photos && page.photos.length) {
    ogImage = page.photos[0];
  } else if (theme.default_og_image) {
    ogImage = theme.default_og_image;
  }
  %>
  <title><% if (title){ %><%= title %> | <% } %><%= config.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

  <%# --- SEO Meta Tags (description handled by open_graph() below) --- %>
  <% if (seoKeywords){ %>
  <meta name="keywords" content="<%= seoKeywords %>">
  <% } %>
  <meta name="author" content="<%= config.author %>">
  <link rel="canonical" href="<%- page.permalink || (config.url + url_for(page.path)) %>">

  <%# --- Open Graph Tags --- %>
  <%- open_graph({
    fb_admins: theme.fb_admins,
    fb_app_id: theme.fb_app_id,
    description: seoDesc,
    image: ogImage
  }) %>

  <%# --- RSS / Atom Feed --- %>
  <link rel="alternate" href="<%- url_for('/atom.xml') %>" title="<%= config.title %>" type="application/atom+xml">

  <% if (theme.favicon){ %>
    <link rel="icon" href="<%- url_for(theme.favicon) %>">
  <% } %>

  <script>
    (function(){var s=localStorage.getItem('theme-preference');if(s==='dark'||((!s)&&window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.setAttribute('data-theme','dark')}})();
  </script>
  <%- css('css/style') %>
  <% if (theme.fancybox){ %>
    <%- css('fancybox/jquery.fancybox') %>
  <% } %>
  <% if (theme.scrollLoading){ %>
    <%- css('scrollLoading/style') %>
  <% } %>
  <%- partial('google-analytics') %>

  <% if (theme.logo){ %>
    <style type="text/css">
      .logo { background-image:url(<%= theme.logo %>); }
    </style>
  <% } %>

  <link href='//fonts.googleapis.com/css?family=Titillium+Web:300,400,600' rel='stylesheet' type='text/css'>
  <link href="//fonts.googleapis.com/css?family=Source+Code+Pro" rel="stylesheet" type="text/css">
  <link href="//fonts.googleapis.com/css?family=Lato" rel="stylesheet">
  <link rel="stylesheet" href="//cdn.datatables.net/1.10.7/css/jquery.dataTables.min.css" media="screen" type="text/css">
  <script src="//code.jquery.com/jquery-2.1.3.min.js"></script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4600841817764546" crossorigin="anonymous"></script>
</head>
